# Backend/serverless environment variables only. Do not put real keys in frontend files.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5-mini

ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-5

XAI_API_KEY=your_xai_api_key_here
XAI_MODEL=grok-4

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-pro

MICROSOFT_AI_API_KEY=your_microsoft_ai_api_key_here
MICROSOFT_AI_ENDPOINT=your_microsoft_ai_endpoint_here
MICROSOFT_AI_MODEL=your_microsoft_model_here

MARKET_DATA_API_KEY=optional_replace_with_market_data_provider_key
ECONOMIC_CALENDAR_API_KEY=optional_replace_with_calendar_provider_key
ALLOWED_ORIGIN=https://yourdomain.com
